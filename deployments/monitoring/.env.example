# APICerebrus Monitoring Stack Environment Variables
# Copy this file to .env and customize for your environment

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
GRAFANA_ROOT_URL=http://localhost:3000

# AlertManager Configuration
ALERTMANAGER_EXTERNAL_URL=http://localhost:9093

# SMTP Configuration for AlertManager
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_FROM=alerts@yourdomain.com
SMTP_AUTH_USERNAME=your-email@gmail.com
SMTP_AUTH_PASSWORD=your-app-password

# Slack Integration (optional)
SLACK_API_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#alerts

# PagerDuty Integration (optional)
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key

# Custom Alertmanager Routes
# Uncomment and modify to customize alert routing
# ALERTMANAGER_CONFIG=/path/to/custom/alertmanager.yml
