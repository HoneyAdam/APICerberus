# APICerebrus Docker Swarm Environment Configuration
# Copy this file to .env and customize

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# NFS Server for shared ACME certificate storage
# REQUIRED for multi-node clusters
# Example: NFS_SERVER=nfs.example.com
# Example: NFS_SERVER=10.0.1.100
NFS_SERVER=

# NFS export paths
NFS_PATH_ACME=/exports/acme
NFS_PATH_DATA=/exports/data

# =============================================================================
# SECURITY
# =============================================================================

# JWT Secret for token signing (auto-generated if empty)
JWT_SECRET=

# Admin panel password (auto-generated if empty)
ADMIN_PASSWORD=

# PostgreSQL password (auto-generated if empty)
DB_PASSWORD=

# =============================================================================
# ACME / LET'S ENCRYPT
# =============================================================================

# Email for Let's Encrypt registration
ACME_EMAIL=admin@example.com

# ACME directory URL
# Production: https://acme-v02.api.letsencrypt.org/directory
# Staging:    https://acme-staging-v02.api.letsencrypt.org/directory
ACME_DIRECTORY_URL=https://acme-v02.api.letsencrypt.org/directory

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection URL
# Format: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://postgres:${DB_PASSWORD}@postgres:5432/apicerberus?sslmode=disable

# =============================================================================
# MONITORING (Optional)
# =============================================================================

# Grafana admin password
# SECURITY: Set this to a secure value before deploying
GRAFANA_PASSWORD=

# =============================================================================
# GATEWAY SETTINGS
# =============================================================================

# Log level: debug, info, warn, error
APICERBERUS_LOG_LEVEL=info

# Number of gateway replicas (can also use: docker service scale apicerberus_gateway=N)
GATEWAY_REPLICAS=3
